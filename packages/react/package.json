{
  "name": "@compa11y/react",
  "version": "0.1.0",
  "description": "Accessible React components that just work",
  "author": "Ivan Trajkovski",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/trajkovskiivan/compa11y#readme",
  "bugs": {
    "url": "https://github.com/trajkovskiivan/compa11y/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/trajkovskiivan/compa11y.git",
    "directory": "packages/react"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dialog": {
      "types": "./dist/components/dialog/index.d.ts",
      "import": "./dist/components/dialog/index.js",
      "require": "./dist/components/dialog/index.cjs"
    },
    "./menu": {
      "types": "./dist/components/menu/index.d.ts",
      "import": "./dist/components/menu/index.js",
      "require": "./dist/components/menu/index.cjs"
    },
    "./tabs": {
      "types": "./dist/components/tabs/index.d.ts",
      "import": "./dist/components/tabs/index.js",
      "require": "./dist/components/tabs/index.cjs"
    },
    "./toast": {
      "types": "./dist/components/toast/index.d.ts",
      "import": "./dist/components/toast/index.js",
      "require": "./dist/components/toast/index.cjs"
    },
    "./combobox": {
      "types": "./dist/components/combobox/index.d.ts",
      "import": "./dist/components/combobox/index.js",
      "require": "./dist/components/combobox/index.cjs"
    },
    "./checkbox": {
      "types": "./dist/components/checkbox/index.d.ts",
      "import": "./dist/components/checkbox/index.js",
      "require": "./dist/components/checkbox/index.cjs"
    },
    "./select": {
      "types": "./dist/components/select/index.d.ts",
      "import": "./dist/components/select/index.js",
      "require": "./dist/components/select/index.cjs"
    },
    "./input": {
      "types": "./dist/components/input/index.d.ts",
      "import": "./dist/components/input/index.js",
      "require": "./dist/components/input/index.cjs"
    },
    "./textarea": {
      "types": "./dist/components/textarea/index.d.ts",
      "import": "./dist/components/textarea/index.js",
      "require": "./dist/components/textarea/index.cjs"
    },
    "./button": {
      "types": "./dist/components/button/index.d.ts",
      "import": "./dist/components/button/index.js",
      "require": "./dist/components/button/index.cjs"
    }
  },
 "files": [
    "dist",      
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@compa11y/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^14.1.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "jsdom": "^23.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "sideEffects": false,
  "keywords": [
    "accessibility",
    "a11y",
    "react",
    "components",
    "dialog",
    "modal",
    "menu",
    "tabs",
    "wcag",
    "aria",
    "input",
    "textarea",
    "button",
    "form"
  ]
}
