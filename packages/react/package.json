{
  "name": "@compa11y/react",
  "version": "0.1.12",
  "description": "Accessible React components that just work",
  "author": "Ivan Trajkovski",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "homepage": "https://compa11y.org",
  "bugs": {
    "url": "https://github.com/trajkovskiivan/compa11y/issues"
  },
