{
  "name": "@a11y-core/web",
  "version": "0.1.0-alpha.4",
  "description": "Accessible Web Components for any HTML page - CDN ready",
  "author": "Ivan Trajkovski",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/trajkovskiivan/a11y-core#readme",
  "bugs": {
    "url": "https://github.com/trajkovskiivan/a11y-core/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/trajkovskiivan/a11y-core.git",
    "directory": "packages/web"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/a11y-core.js",
      "require": "./dist/a11y-core.umd.cjs"
    },
    "./dialog": {
      "types": "./dist/components/dialog.d.ts",
      "import": "./dist/components/dialog.js"
    },
    "./menu": {
      "types": "./dist/components/menu.d.ts",
      "import": "./dist/components/menu.js"
    },
    "./tabs": {
      "types": "./dist/components/tabs.d.ts",
      "import": "./dist/components/tabs.js"
    },
    "./combobox": {
      "types": "./dist/components/combobox.d.ts",
      "import": "./dist/components/combobox.js"
    },
    "./switch": {
      "types": "./dist/components/switch.d.ts",
      "import": "./dist/components/switch.js"
    }
  },
  "unpkg": "./dist/a11y-core.iife.js",
  "jsdelivr": "./dist/a11y-core.iife.js",
  "files": [
    "dist",     
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@a11y-core/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.2.0"
  },
  "sideEffects": true,
  "keywords": [
    "accessibility",
    "a11y",
    "web-components",
    "custom-elements",
    "cdn",
    "dialog",
    "modal",
    "menu",
    "tabs",
    "combobox",
    "autocomplete",
    "select",
    "switch",
    "toggle"
  ]
}
