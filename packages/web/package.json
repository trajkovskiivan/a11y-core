{
  "name": "@compa11y/web",
  "version": "0.1.9",
  "description": "Accessible Web Components for any HTML page - CDN ready",
  "author": "Ivan Trajkovski",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "homepage": "https://compa11y.org",
  "bugs": {
    "url": "https://github.com/trajkovskiivan/compa11y/issues"
},
  "repository": {
    "type": "git",
    "url": "https://github.com/trajkovskiivan/compa11y.git",
    "directory": "packages/web"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/compa11y.js",
      "require": "./dist/compa11y.umd.cjs"
    },
    "./dialog": {
      "types": "./dist/components/dialog.d.ts",
      "import": "./dist/components/dialog.js"
    },
    "./menu": {
      "types": "./dist/components/menu.d.ts",
      "import": "./dist/components/menu.js"
    },
    "./tabs": {
      "types": "./dist/components/tabs.d.ts",
      "import": "./dist/components/tabs.js"
    },
    "./combobox": {
      "types": "./dist/components/combobox.d.ts",
      "import": "./dist/components/combobox.js"
    },
    "./switch": {
      "types": "./dist/components/switch.d.ts",
      "import": "./dist/components/switch.js"
    },
    "./checkbox": {
      "types": "./dist/components/checkbox.d.ts",
      "import": "./dist/components/checkbox.js"
    },
    "./select": {
      "types": "./dist/components/select.d.ts",
      "import": "./dist/components/select.js"
    },
    "./input": {
      "types": "./dist/components/input.d.ts",
      "import": "./dist/components/input.js"
    },
    "./textarea": {
      "types": "./dist/components/textarea.d.ts",
      "import": "./dist/components/textarea.js"
    },
    "./button": {
      "types": "./dist/components/button.d.ts",
      "import": "./dist/components/button.js"
    },
    "./radio-group": {
      "types": "./dist/components/radio-group.d.ts",
      "import": "./dist/components/radio-group.js"
    },
    "./listbox": {
      "types": "./dist/components/listbox.d.ts",
      "import": "./dist/components/listbox.js"
    }
  },
  "unpkg": "./dist/compa11y.iife.js",
  "jsdelivr": "./dist/compa11y.iife.js",
  "files": [
    "dist",     
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@compa11y/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.2.0"
  },
  "sideEffects": true,
  "keywords": [
    "accessibility",
    "a11y",
    "web-components",
    "custom-elements",
    "cdn",
    "dialog",
    "modal",
    "menu",
    "tabs",
    "combobox",
    "autocomplete",
    "select",
    "switch",
    "toggle",
    "checkbox",
    "input",
    "textarea",
    "button",
    "radio-group",
    "radio",
    "listbox",
    "form"
  ]
}
