{
  "name": "@a11ykit/web",
  "version": "0.1.0",
  "description": "Accessible Web Components for any HTML page - CDN ready",
  "author": "Ivan Trajkovski",
  "license": "MIT",
  "type": "module",
  "main": "./dist/a11ykit.js",
  "module": "./dist/a11ykit.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/a11ykit.js",
      "require": "./dist/a11ykit.umd.cjs"
    },
    "./dialog": {
      "types": "./dist/components/dialog.d.ts",
      "import": "./dist/components/dialog.js"
    },
    "./menu": {
      "types": "./dist/components/menu.d.ts",
      "import": "./dist/components/menu.js"
    },
    "./tabs": {
      "types": "./dist/components/tabs.d.ts",
      "import": "./dist/components/tabs.js"
    },
    "./combobox": {
      "types": "./dist/components/combobox.d.ts",
      "import": "./dist/components/combobox.js"
    }
  },
  "unpkg": "./dist/a11ykit.iife.js",
  "jsdelivr": "./dist/a11ykit.iife.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@a11ykit/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.2.0"
  },
  "sideEffects": true,
  "keywords": [
    "accessibility",
    "a11y",
    "web-components",
    "custom-elements",
    "cdn",
    "dialog",
    "modal",
    "menu",
    "tabs",
    "combobox",
    "autocomplete",
    "select"
  ]
}
